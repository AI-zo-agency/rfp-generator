PORT=8001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_URL=http://localhost:3000

# Shared with rfp-dashboard (relative to backend/)
DATABASE_PATH=../rfp-dashboard/data/rfps.db
PDF_STORAGE_PATH=../rfp-dashboard/storage/pdfs

# Supabase — Postgres (primary when configured) + Storage (RFP PDFs)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RFP_BUCKET=rfp-pdfs

# Supermemory — one container tag for proposals, KB, and all RFP content
SUPERMEMORY_API_KEY=
SUPERMEMORY_CONTAINER_TAG=zo-agency

# Google Drive OAuth (your user account — not a service account)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional shared drive name for folder listing API
GOOGLE_DRIVE_SHARED_DRIVE_NAME=RFPs

# Optional: bulk ingest script (scripts/ingest_drive_folder_to_supermemory.py)
# DRIVE_INGEST_FOLDER_ID=

# Go/No-Go analysis — OpenRouter primary, Fireworks fallback
# Leave OPENROUTER_API_KEY empty if you only use Fireworks
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
